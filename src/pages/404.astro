---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 - Not found">
  <section class="container not-found">
    <h1>404</h1>
    <p>This page doesn't exist &mdash; like a turtle in its shell.</p>
    <p>
      <a href="/" class="btn btn--primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform: rotate(180deg); margin-right: 0.1rem;">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        <span>Back to home</span>
      </a>
    </p>
  </section>
</Layout>
