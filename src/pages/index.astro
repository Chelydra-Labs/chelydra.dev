---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---
<Layout>
  <section class="container hero">
    <div class="hero__inner">
      <div class="hero__content">
        <span class="hero__tagline">Chelydra Labs</span>
        <h1 class="hero__title">Resilient, Low-Level Engineering</h1>
        <p class="hero__desc">
          Home for a family of open-source projects. Built to last and engineered for high-performance &mdash; like the snapping turtle we take our name from.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="#projects">
            <span>View projects</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 5v14M5 12l7 7 7-7"/>
            </svg>
          </a>
          <a class="btn" href="https://github.com/Chelydra-Labs" rel="noopener noreferrer" target="_blank">
            <span>GitHub</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__logo-wrapper">
          <div class="hero__logo-glow"></div>
          <Image
            src={logo}
            alt="Chelydra Labs Snapping Turtle Mascot"
            width={280}
            height={280}
            class="hero__logo"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container" id="projects" style="padding-bottom: 4rem;">
    <h2>Featured Projects</h2>
    <div class="project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Layout>
