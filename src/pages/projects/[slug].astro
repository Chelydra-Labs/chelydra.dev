---
import Layout from '../../layouts/Layout.astro';
import ReleaseList from '../../components/ReleaseList.astro';
import { getEntry, render } from 'astro:content';
import { getLatestRelease } from '../../lib/github';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
  return new Response('Not found', { status: 404 });
}

const project = await getEntry('projects', slug);
if (!project) {
  return new Response('Not found', { status: 404 });
}

const { title, tagline, repo, homepage, docs, license, language } = project.data;

const release = await getLatestRelease(repo);
const { Content } = await render(project);
---
<Layout title={title} description={tagline}>
  <article class="container project-layout">
    <header class="project-header">
      <h1>{title}</h1>
      <p class="tagline">{tagline}</p>
      <div class="project-meta">
        {language && <span class="tag">{language}</span>}
        {license && <span class="tag">{license}</span>}
        <span class="tag">{repo}</span>
      </div>
    </header>

    <div class="project-grid-layout">
      <!-- Main Content Column -->
      <div class="project-main-content">
        <section class="section">
          <div class="prose">
            <Content />
          </div>
        </section>
      </div>

      <!-- Sidebar Column -->
      <aside class="project-sidebar">
        <div class="sidebar-panel">
          <div>
            <h2 class="sidebar-panel__title">Latest Release</h2>
            <ReleaseList release={release} repo={repo} />
          </div>

          <div class="sidebar-links">
            <h3 class="sidebar-links__title">Resources</h3>
            <div class="link-grid">
              {homepage && (
                <a href={homepage} class="link-item" target="_blank" rel="noopener noreferrer">
                  <span>Homepage</span>
                  <span class="link-item__icon">&rarr;</span>
                </a>
              )}
              {docs && (
                <a href={docs} class="link-item" target="_blank" rel="noopener noreferrer">
                  <span>Documentation</span>
                  <span class="link-item__icon">&rarr;</span>
                </a>
              )}
              <a href={`https://github.com/${repo}`} class="link-item" target="_blank" rel="noopener noreferrer">
                <span>GitHub Repository</span>
                <span class="link-item__icon">&rarr;</span>
              </a>
              <a href={`https://github.com/${repo}/issues`} class="link-item" target="_blank" rel="noopener noreferrer">
                <span>Issue Tracker</span>
                <span class="link-item__icon">&rarr;</span>
              </a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </article>
</Layout>
