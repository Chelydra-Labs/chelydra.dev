---
import type { Release, Platform, ReleaseAsset } from '../lib/github';
import { formatBytes } from '../lib/github';

interface Props {
  release: Release | null;
  repo: string;
}
const { release, repo } = Astro.props;

const PLATFORM_ORDER: Platform[] = ['windows', 'linux', 'macos', 'other'];
const PLATFORM_LABELS: Record<Platform, string> = {
  windows: 'Windows',
  linux: 'Linux',
  macos: 'macOS',
  other: 'Other',
};

const published = release
  ? new Date(release.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';

const grouped: Record<Platform, ReleaseAsset[]> = {
  windows: [],
  linux: [],
  macos: [],
  other: [],
};
if (release) {
  for (const asset of release.assets) {
    grouped[asset.platform].push(asset);
  }
}
const releasesUrl = `https://github.com/${repo}/releases`;
---
{release === null ? (
  <div class="release-empty">
    <p style="margin:0 0 0.75rem; font-weight: 500;">No published releases yet.</p>
    <a href={releasesUrl} rel="noopener noreferrer" target="_blank" class="btn btn--sm">
      <span>View tags on GitHub</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
) : (
  <div class="release-card">
    <div class="release-card__header">
      <span class="release-card__tag">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent); vertical-align: middle; margin-right: 0.4rem; display: inline-block;" aria-hidden="true">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        {release.tagName}
      </span>
      <span class="release-card__date">{published}</span>
    </div>

    {PLATFORM_ORDER.filter((p) => grouped[p].length > 0).map((platform) => (
      <div class="platform-group">
        <div class="platform-group__label">
          {platform === 'windows' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 0.3rem; vertical-align: -1px; display: inline-block;" aria-hidden="true">
              <path d="M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z"/>
            </svg>
          )}
          {platform === 'linux' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 0.3rem; vertical-align: -1px; display: inline-block;" aria-hidden="true">
              <path d="M4 17l6-6-6-6M12 19h8"/>
            </svg>
          )}
          {platform === 'macos' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 0.3rem; vertical-align: -1px; display: inline-block;" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          )}
          {platform === 'other' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 0.3rem; vertical-align: -1px; display: inline-block;" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          )}
          {PLATFORM_LABELS[platform]}
        </div>
        <ul class="download-list">
          {grouped[platform].map((asset) => (
            <li>
              <a class="download-link" href={asset.url} rel="noopener noreferrer" target="_blank">
                <span class="download-link__name" title={asset.name}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.4rem; color: var(--text-dim); display: inline-block; vertical-align: middle;" aria-hidden="true">
                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                  </svg>
                  {asset.name}
                </span>
                <span class="download-link__info">
                  {asset.size > 0 && <span class="download-link__size">{formatBytes(asset.size)}</span>}
                  <svg class="download-link__arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.4rem; color: var(--accent); opacity: 0.6; display: inline-block; vertical-align: middle;" aria-hidden="true">
                    <path d="M12 5v14M5 12l7 7 7-7"/>
                  </svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div style="margin-top:1.25rem; padding-top:1rem; border-top:1px solid var(--border-glass); font-size:0.85rem; display: flex; justify-content: flex-end;">
      <a href={releasesUrl} rel="noopener noreferrer" target="_blank" class="releases-all-link">
        All releases &rarr;
      </a>
    </div>
  </div>
)}

<style>
  .releases-all-link {
    font-family: var(--mono);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: lowercase;
  }
  .releases-all-link:hover {
    color: var(--accent);
  }
  .download-link__name {
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 200px;
  }
  @media (min-width: 480px) {
    .download-link__name {
      max-width: 250px;
    }
  }
  .download-link__info {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .download-link__arrow {
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
  }
  .download-link:hover .download-link__arrow {
    transform: translateY(2px);
    opacity: 1;
  }
  .btn--sm {
    padding: 0.45rem 0.9rem;
    font-size: 0.8rem;
    gap: 0.4rem;
  }
</style>
