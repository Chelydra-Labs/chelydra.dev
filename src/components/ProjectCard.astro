---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, tagline, repo, language, license, accent } = project.data;
const href = `/projects/${project.id}`;
---
<a href={href} class="card" style={accent ? `--accent-card: ${accent};` : undefined}>
  <h3 class="card__title">{title}</h3>
  <p class="card__tagline">{tagline}</p>
  <div class="card__meta">
    {language && <span class="tag">{language}</span>}
    {license && <span class="tag">{license}</span>}
    <span class="tag">{repo.split('/')[0]}</span>
  </div>
</a>
