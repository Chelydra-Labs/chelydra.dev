# Optional: GitHub token to raise the unauthenticated API rate limit
# (60 req/hr) when fetching live release data for project pages.
# Create a fine-grained token with public-read on the project repos.
# Without it, the site still works but may hit rate limits under load.
GITHUB_TOKEN=

# Contact email shown on the site. Defaults to turtle@chelydra.dev if unset.
CONTACT_EMAIL=turtle@chelydra.dev
